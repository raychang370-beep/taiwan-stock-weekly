{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/config",       "function": "api_config",       "region": "asia-east1" },
      { "source": "/api/add-stock",    "function": "api_add_stock",    "region": "asia-east1" },
      { "source": "/api/remove-stock", "function": "api_remove_stock", "region": "asia-east1" },
      { "source": "/api/run",          "function": "run_analysis",     "region": "asia-east1" }
    ],
    "headers": [
      {
        "source": "/api/**",
        "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["venv", ".git", "**/.git/**", ".gcloudignore", "**/__pycache__/**"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
